{
    "name": "wikitext-front",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsgo && vite build",
        "preview": "vite preview",
        "typecheck": "tsgo --noEmit",
        "lint": "oxlint --silent",
        "lint:strict": "oxlint --deny-warnings",
        "check:file": "oxlint",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "check": "pnpm typecheck && pnpm lint:strict && pnpm format:check"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.11.2",
        "idb": "^8.0.3",
        "nanoid": "^5.1.11",
        "neverthrow": "^8.2.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.15.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.15",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.6.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260510.1",
        "@vitejs/plugin-react": "^6.0.1",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^10.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.6.0",
        "jsdom": "^29.1.1",
        "oxlint": "^1.63.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.59.2",
        "vite": "^8.0.11",
        "vitest": "^3.2.4"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ],
        "ignoredBuiltDependencies": [
            "esbuild"
        ]
    }
}

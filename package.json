{
    "name": "wikitext-front",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsgo && vite build",
        "preview": "vite preview",
        "typecheck": "tsgo --noEmit",
        "lint": "oxlint --silent",
        "lint:strict": "oxlint --deny-warnings",
        "check:file": "oxlint",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "check": "pnpm typecheck && pnpm lint:strict && pnpm format:check"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.8.2",
        "idb": "^8.0.3",
        "nanoid": "^5.1.5",
        "neverthrow": "^8.2.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.7.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.1.2",
        "@eslint/js": "^9.25.0",
        "@types/node": "^24.0.3",
        "@types/react": "^19.1.2",
        "@types/react-dom": "^19.1.2",
        "@typescript/native-preview": "7.0.0-dev.20250621.1",
        "@vitejs/plugin-react": "^4.4.1",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.25.0",
        "eslint-plugin-react-hooks": "^5.2.0",
        "eslint-plugin-react-refresh": "^0.4.19",
        "globals": "^16.3.0",
        "jsdom": "^26.1.0",
        "oxlint": "^1.2.0",
        "typescript": "~5.8.3",
        "typescript-eslint": "^8.30.1",
        "vite": "^6.3.5",
        "vitest": "^3.2.4"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ],
        "ignoredBuiltDependencies": [
            "esbuild"
        ]
    }
}

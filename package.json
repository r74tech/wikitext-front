{
    "name": "wikitext-front",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsgo && vite build",
        "preview": "vite preview",
        "typecheck": "tsgo --noEmit",
        "lint": "oxlint --silent",
        "lint:strict": "oxlint --deny-warnings",
        "check:file": "oxlint",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "check": "pnpm typecheck && pnpm lint:strict && pnpm format:check"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.11.2",
        "idb": "^8.0.3",
        "nanoid": "^5.1.6",
        "neverthrow": "^8.2.0",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-redux": "^9.2.0",
        "react-router-dom": "^7.11.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.3.10",
        "@eslint/js": "^9.39.2",
        "@types/node": "^25.0.3",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20251228.1",
        "@vitejs/plugin-react": "^5.1.2",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.39.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.26",
        "globals": "^16.5.0",
        "jsdom": "^27.3.0",
        "oxlint": "^1.34.0",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.50.0",
        "vite": "^7.3.0",
        "vitest": "^3.2.4"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ],
        "ignoredBuiltDependencies": [
            "esbuild"
        ]
    }
}

{
	"$schema": "https://biomejs.dev/schemas/2.0.4/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"semicolons": "always"
		}
	},
	"linter": {
		"rules": {
			"nursery": {
				"useUniqueElementIds": "off"
			}
		}
	},
	"files": {
		"ignoreUnknown": true,
		"includes": ["src/**/*", "*.json", "*.ts", "*.tsx", "*.js", "*.jsx"],
		"maxSize": 10485760
	}
}
